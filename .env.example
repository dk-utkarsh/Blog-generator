# Google Gemini API — for blog content generation
# Read automatically by @ai-sdk/google — do not rename
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Neon Postgres (or any Postgres) connection string
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# Secret for protecting the /api/generate cron endpoint
CRON_SECRET=a-long-random-string
NEXT_PUBLIC_CRON_SECRET=same-as-above-for-client-use

# DentalKart blog admin credentials (for auto-publishing)
DENTALKART_BLOG_URL=https://www.dentalkart.com/blogs
DENTALKART_ADMIN_EMAIL=admin@example.com
DENTALKART_ADMIN_PASSWORD=your-password
